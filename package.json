{
  "name": "ai-heritage-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @ai-heritage/web --filter @ai-heritage/admin --filter @ai-heritage/api --filter @ai-heritage/worker dev",
    "build": "corepack pnpm -r build",
    "db:format": "node packages/database/scripts/prisma-cli.mjs format",
    "db:generate": "node packages/database/scripts/prisma-cli.mjs generate",
    "db:migrate:deploy": "node packages/database/scripts/prisma-cli.mjs migrate deploy",
    "db:migrate:dev": "node packages/database/scripts/prisma-cli.mjs migrate dev",
    "db:seed": "corepack pnpm --filter @ai-heritage/database db:seed",
    "db:studio": "node packages/database/scripts/prisma-cli.mjs studio",
    "db:validate": "node packages/database/scripts/prisma-cli.mjs validate",
    "e2e": "vitest run e2e --passWithNoTests",
    "e2e:local": "corepack pnpm e2e:setup && corepack pnpm e2e && corepack pnpm e2e:teardown",
    "e2e:local-stack": "corepack pnpm local:stack && corepack pnpm e2e",
    "e2e:setup": "node e2e/scripts/setup.mjs",
    "e2e:smoke": "vitest run e2e/mvp-happy-path.e2e.test.ts e2e/failure-and-security.e2e.test.ts e2e/gap-report.e2e.test.ts --passWithNoTests",
    "e2e:teardown": "node e2e/scripts/teardown.mjs",
    "e2e:web": "vitest run apps/web/src/customer-flow.test.tsx apps/web/src/security-hardening.test.tsx --passWithNoTests",
    "lint": "eslint .",
    "local:admin": "corepack pnpm --filter @ai-heritage/admin dev",
    "local:api": "corepack pnpm --filter @ai-heritage/api dev",
    "local:db:up": "docker compose up -d mysql",
    "local:redis:up": "docker compose up -d redis",
    "local:seed": "corepack pnpm db:seed",
    "local:stack": "docker compose up -d mysql redis && corepack pnpm db:validate && corepack pnpm db:generate && corepack pnpm db:seed",
    "local:web": "corepack pnpm --filter @ai-heritage/web dev",
    "local:worker": "corepack pnpm --filter @ai-heritage/worker dev",
    "test": "vitest run --passWithNoTests",
    "security:check": "vitest run apps/web/src/security-hardening.test.tsx apps/admin/src/admin-security.test.ts packages/validation/src/security-hardening.test.ts apps/api/src/payments/payments.service.test.ts apps/api/src/payments/stripe-webhook.service.test.ts",
    "staging:admin": "corepack pnpm --filter @ai-heritage/admin build && corepack pnpm --filter @ai-heritage/admin start",
    "staging:api": "corepack pnpm --filter @ai-heritage/api build && corepack pnpm --filter @ai-heritage/api start",
    "staging:db:up": "docker compose -f docker-compose.staging.yml up -d mysql",
    "staging:down": "docker compose -f docker-compose.staging.yml down",
    "staging:e2e": "vitest run e2e/staging-smoke.test.ts e2e/mvp-happy-path.e2e.test.ts e2e/failure-and-security.e2e.test.ts --passWithNoTests",
    "staging:migrate": "corepack pnpm db:migrate:deploy",
    "staging:redis:up": "docker compose -f docker-compose.staging.yml up -d redis",
    "staging:seed": "corepack pnpm db:seed",
    "staging:smoke": "node scripts/staging-smoke.mjs",
    "staging:stack": "docker compose -f docker-compose.staging.yml up -d mysql redis api worker web admin",
    "staging:web": "corepack pnpm --filter @ai-heritage/web build && corepack pnpm --filter @ai-heritage/web start",
    "staging:worker": "corepack pnpm --filter @ai-heritage/worker build && corepack pnpm --filter @ai-heritage/worker start",
    "typecheck": "corepack pnpm -r typecheck",
    "format": "prettier --write .",
    "clean": "rimraf --glob \"apps/*/.next\" \"apps/*/dist\" \"packages/*/dist\" coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@next/eslint-plugin-next": "15.5.4",
    "@types/node": "^24.5.2",
    "eslint": "^9.36.0",
    "prettier": "^3.6.2",
    "prisma": "^6.19.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.2.4"
  }
}
