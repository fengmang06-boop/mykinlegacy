# MyKinLegacy production bootstrap example.
# Copy to .env.production on the server. Do not commit real production secrets.

NODE_ENV=production
APP_ENV=production

DOMAIN=mykinlegacy.com
LETSENCRYPT_EMAIL=support@mykinlegacy.com

APP_WEB_URL=https://mykinlegacy.com
API_PUBLIC_URL=https://mykinlegacy.com
NEXT_PUBLIC_SITE_URL=https://mykinlegacy.com
APP_BASE_URL=https://mykinlegacy.com
API_BASE_URL=https://mykinlegacy.com
NEXT_PUBLIC_API_BASE_URL=https://mykinlegacy.com/api/v1

MYSQL_DATABASE=mykinlegacy
MYSQL_USER=mykinlegacy
MYSQL_PASSWORD=replace_me_generate_on_server
MYSQL_ROOT_PASSWORD=replace_me_generate_on_server

DATABASE_URL=mysql://mykinlegacy:replace_me_generate_on_server@mysql:3306/mykinlegacy
DIRECT_URL=mysql://mykinlegacy:replace_me_generate_on_server@mysql:3306/mykinlegacy
REDIS_URL=redis://redis:6379

API_PORT=4000
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_MS=5000
WORKER_ENABLE_OUTBOX_DISPATCHER=true

STRIPE_SECRET_KEY=replace_me_live_key_later
STRIPE_WEBHOOK_SECRET=replace_me_live_webhook_secret_later
STRIPE_API_VERSION=
STRIPE_SUCCESS_PATH=/payment/success
STRIPE_CANCEL_PATH=/payment/cancel

AI_PROVIDER=mock
AI_PROVIDER_API_KEY=replace_me_later
OPENAI_API_KEY=replace_me_later
OPENAI_IMAGE_MODEL=mock-image-model
OPENAI_TEXT_MODEL=mock-text-model
AI_GENERATION_TIMEOUT_MS=180000
AI_IMAGE_MAX_ATTEMPTS=3
AI_TEXT_MAX_ATTEMPTS=3

EMAIL_PROVIDER=mock
EMAIL_FROM=support@mykinlegacy.com
EMAIL_REPLY_TO=support@mykinlegacy.com
RESEND_API_KEY=replace_me_later
SENDGRID_API_KEY=replace_me_later
SES_REGION=replace_me_later

STORAGE_PROVIDER=local_private
LOCAL_STORAGE_DIR=./.local-storage-production
STORAGE_BUCKET=mykinlegacy-local-private
S3_BUCKET=replace_me_later
S3_REGION=replace_me_later
S3_ACCESS_KEY_ID=replace_me_later
S3_SECRET_ACCESS_KEY=replace_me_later
R2_BUCKET=replace_me_later
R2_ACCOUNT_ID=replace_me_later
R2_ACCESS_KEY_ID=replace_me_later
R2_SECRET_ACCESS_KEY=replace_me_later

ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=admin@mykinlegacy.com
ADMIN_BOOTSTRAP_PASSWORD=replace_me_disable_or_rotate
ADMIN_SESSION_SECRET=replace_me_generate_on_server

RECOVERY_SCAN_ENABLED=true
RECOVERY_SCAN_INTERVAL_MS=300000
CLEANUP_DESTRUCTIVE_ENABLED=false
STUCK_ORDER_THRESHOLD_MINUTES=30
