# Staging example configuration only. Do not commit real secrets.
# Staging secrets must be injected by a secret manager or server environment variables.
# Use Stripe test mode only. Keep AI and email providers mocked for MVP staging.

NODE_ENV="staging"
APP_ENV="staging"

APP_WEB_URL="https://staging.mykinlegacy.com"
API_PUBLIC_URL="https://api-staging.mykinlegacy.com"
ADMIN_WEB_URL="https://admin-staging.mykinlegacy.com"
NEXT_PUBLIC_SITE_URL="https://staging.mykinlegacy.com"
APP_BASE_URL="https://staging.mykinlegacy.com"
ADMIN_BASE_URL="https://admin-staging.mykinlegacy.com"
API_BASE_URL="https://api-staging.mykinlegacy.com"
NEXT_PUBLIC_API_BASE_URL="https://api-staging.mykinlegacy.com/api/v1"

DATABASE_URL="replace_me"
DIRECT_URL="replace_me"
REDIS_URL="replace_me"

API_PORT="4000"
WORKER_CONCURRENCY="2"
WORKER_POLL_INTERVAL_MS="5000"
WORKER_ENABLE_OUTBOX_DISPATCHER="true"

STRIPE_SECRET_KEY="replace_me_test_key_only"
STRIPE_WEBHOOK_SECRET="replace_me_test_webhook_secret"
STRIPE_API_VERSION=""
STRIPE_SUCCESS_PATH="/payment/success"
STRIPE_CANCEL_PATH="/payment/cancel"

AI_PROVIDER="mock"
AI_PROVIDER_API_KEY="replace_me_not_used_for_mock"
OPENAI_API_KEY="replace_me_not_used_for_mock"
OPENAI_IMAGE_MODEL="mock-image-model"
OPENAI_TEXT_MODEL="mock-text-model"
AI_GENERATION_TIMEOUT_MS="180000"
AI_IMAGE_MAX_ATTEMPTS="3"
AI_TEXT_MAX_ATTEMPTS="3"

EMAIL_PROVIDER="mock"
EMAIL_FROM="support@mykinlegacy.com"
EMAIL_REPLY_TO="support@mykinlegacy.com"
RESEND_API_KEY="replace_me_not_used_for_mock"
SENDGRID_API_KEY="replace_me_not_used_for_mock"
SES_REGION="replace_me"

STORAGE_PROVIDER="local_private"
LOCAL_STORAGE_DIR="./.local-storage-staging"
STORAGE_BUCKET="ai-heritage-staging-local-private"
S3_BUCKET="replace_me_not_used"
S3_REGION="replace_me_not_used"
S3_ACCESS_KEY_ID="replace_me_not_used"
S3_SECRET_ACCESS_KEY="replace_me_not_used"
R2_BUCKET="replace_me_not_used"
R2_ACCOUNT_ID="replace_me_not_used"
R2_ACCESS_KEY_ID="replace_me_not_used"
R2_SECRET_ACCESS_KEY="replace_me_not_used"

ADMIN_BOOTSTRAP_ENABLED="false"
ADMIN_BOOTSTRAP_EMAIL="admin@mykinlegacy.com"
ADMIN_BOOTSTRAP_PASSWORD="replace_me_from_secret_manager"
ADMIN_SESSION_SECRET="replace_me"

RECOVERY_SCAN_ENABLED="true"
RECOVERY_SCAN_INTERVAL_MS="300000"
CLEANUP_DESTRUCTIVE_ENABLED="false"
STUCK_ORDER_THRESHOLD_MINUTES="30"
