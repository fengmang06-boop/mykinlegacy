# Example configuration only. Do not commit real secrets.
# Production secrets must be injected by a secret manager or deployment platform vault.

NODE_ENV="development"
APP_ENV="local"
NEXT_PUBLIC_SITE_URL="https://mykinlegacy.com"
APP_BASE_URL="https://mykinlegacy.com"
APP_WEB_URL="https://mykinlegacy.com"
ADMIN_BASE_URL="http://localhost:3001"
API_BASE_URL="http://localhost:4000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
CUSTOMER_PII_ENCRYPTION_KEY="replace_with_customer_pii_encryption_key_from_secret_manager"

# Database - placeholder only.
DATABASE_URL="mysql://user:password@localhost:3306/ai_heritage"
DIRECT_URL="mysql://user:password@localhost:3306/ai_heritage"

# Queue
REDIS_URL="redis://localhost:6379"
WORKER_CONCURRENCY="2"
WORKER_POLL_INTERVAL_MS="5000"
WORKER_ENABLE_OUTBOX_DISPATCHER="true"

# Recovery - destructive cleanup is disabled by default.
RECOVERY_SCAN_ENABLED="true"
RECOVERY_SCAN_INTERVAL_MS="300000"
CLEANUP_DESTRUCTIVE_ENABLED="false"
STUCK_ORDER_THRESHOLD_MINUTES="30"

# Payments - placeholders only.
STRIPE_SECRET_KEY="replace_with_stripe_secret_from_secret_manager"
STRIPE_WEBHOOK_SECRET="replace_with_stripe_webhook_secret_from_secret_manager"
STRIPE_API_VERSION=""
STRIPE_SUCCESS_PATH="/payment/success"
STRIPE_CANCEL_PATH="/payment/cancel"

# AI Provider - placeholders only.
AI_PROVIDER="mock"
AI_PROVIDER_API_KEY="replace_with_provider_key_from_secret_manager"
OPENAI_API_KEY="replace_with_openai_key_from_secret_manager"
OPENAI_IMAGE_MODEL="image-model-placeholder"
OPENAI_TEXT_MODEL="text-model-placeholder"
AI_GENERATION_TIMEOUT_MS="180000"
AI_IMAGE_MAX_ATTEMPTS="3"
AI_TEXT_MAX_ATTEMPTS="3"

# Storage - private storage only.
STORAGE_PROVIDER="local_private"
LOCAL_STORAGE_DIR="./.local-storage"
STORAGE_BUCKET="ai-heritage-local-private"
S3_BUCKET="replace_me"
S3_REGION="replace_me"
S3_ACCESS_KEY_ID="replace_me"
S3_SECRET_ACCESS_KEY="replace_with_s3_secret_from_secret_manager"
R2_BUCKET="replace_me"
R2_ACCOUNT_ID="replace_me"
R2_ACCESS_KEY_ID="replace_me"
R2_SECRET_ACCESS_KEY="replace_with_r2_secret_from_secret_manager"

# Email - placeholders only.
EMAIL_PROVIDER="log"
EMAIL_FROM="support@mykinlegacy.com"
EMAIL_REPLY_TO="support@mykinlegacy.com"
RESEND_API_KEY="replace_with_resend_key_from_secret_manager"
SENDGRID_API_KEY="replace_with_sendgrid_key_from_secret_manager"
SES_REGION="replace_me"
EMAIL_DELIVERY_TEST_MODE="false"
EMAIL_TEST_RECIPIENT=""

# Legacy Reasoning Engine controlled integration - disabled by default.
ENABLE_LRE_PRODUCT_EXPERIENCE="false"
ENABLE_LRE_PRODUCT_EXPERIENCE_DRY_RUN="false"
LRE_DRY_RUN_ORDER_NUMBER=""
LRE_PRODUCT_EXPERIENCE_ORDER_ALLOWLIST=""
LRE_IMAGE_PROMPT_ORDER_ALLOWLIST=""

# Admin - placeholders only.
ADMIN_BOOTSTRAP_EMAIL="admin@mykinlegacy.com"
ADMIN_BOOTSTRAP_PASSWORD="replace_with_admin_bootstrap_password_from_secret_manager"
ADMIN_SESSION_SECRET="replace_with_admin_session_secret_from_secret_manager"
ADMIN_BOOTSTRAP_ENABLED="false"
