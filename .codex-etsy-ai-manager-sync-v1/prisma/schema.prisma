generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Shop {
  id         String    @id @default(cuid())
  etsyShopId String?   @unique
  name       String
  url        String?
  currency   String?
  rawJson    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  listings   Listing[]
  syncLogs   SyncLog[]
  receipts   EtsyReceipt[]
  transactions EtsyTransaction[]
}

model Listing {
  id              String                       @id @default(cuid())
  shopId          String
  etsyListingId   String                       @unique
  title           String
  description     String
  price           Float
  currency        String?
  quantity        Int
  state           String
  tags            String
  materials       String
  productType     String
  targetCustomer  String
  url             String?
  rawJson         String?
  lastSyncedAt    DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  shop            Shop                         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  images          ListingImage[]
  inventory       ListingInventory?
  aiReports       ListingAiReport[]
  keywords        ListingKeyword[]
  scores          ListingScore[]
  bestsellerScores BestsellerScore[]
  promotionTasks  PromotionTask[]
  exportLogs      ExportLog[]
  recommendations OptimizationRecommendation[]
  aiSnapshots     ListingAiSnapshot[]
  optimizationQueueItems OptimizationQueueItem[]
  growthPlans     EtsyGrowthPlan[]
  growthTrackings EtsyGrowthDailyTracking[]
  growthBaselines EtsyGrowthBaseline[]
}

model ListingAiReport {
  id               String   @id @default(cuid())
  listingId        String   @map("listing_id")
  seoScore         Int      @map("seo_score")
  titleScore       Int      @map("title_score")
  tagScore         Int      @map("tag_score")
  imageScore       Int      @map("image_score")
  conversionScore  Int      @map("conversion_score")
  pricingScore     Int      @map("pricing_score")
  competitionScore Int      @map("competition_score")
  freshnessScore   Int      @map("freshness_score")
  opportunityScore  Int      @default(0) @map("opportunity_score")
  overallPriority  String   @map("overall_priority")
  riskLevel        String   @map("risk_level")
  recommendedActions String @map("recommended_actions")
  scoreBreakdown   String   @default("{}") @map("score_breakdown")
  analysisVersion  String   @map("analysis_version")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([opportunityScore])
  @@index([overallPriority])
  @@index([riskLevel])
  @@map("listing_ai_report")
}

model ListingAiSnapshot {
  id               String   @id @default(cuid())
  listingId        String   @map("listing_id")
  reportId         String?  @map("report_id")
  seoScore         Int      @map("seo_score")
  conversionScore  Int      @map("conversion_score")
  opportunityScore Int      @map("opportunity_score")
  overallPriority  String   @map("overall_priority")
  riskLevel        String   @map("risk_level")
  snapshotJson     String   @map("snapshot_json")
  analysisVersion  String   @map("analysis_version")
  createdAt        DateTime @default(now()) @map("created_at")
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([createdAt])
  @@index([opportunityScore])
  @@map("listing_ai_snapshot")
}

model OptimizationQueueItem {
  id               String   @id @default(cuid())
  queueDate        String   @map("queue_date")
  listingId        String   @map("listing_id")
  reportId         String?  @map("report_id")
  rank             Int
  opportunityScore Int      @map("opportunity_score")
  priority         String
  riskLevel        String   @map("risk_level")
  taskType         String   @map("task_type")
  taskTitle        String   @map("task_title")
  taskReason       String   @map("task_reason")
  evidenceJson     String   @map("evidence_json")
  status           String   @default("pending")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([queueDate, listingId, taskType])
  @@index([queueDate])
  @@index([opportunityScore])
  @@index([status])
  @@map("optimization_queue")
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  etsyImageId String?
  url       String
  alt       String
  position  Int
  role      String
  rawJson   String?
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingInventory {
  id            String   @id @default(cuid())
  listingId     String   @unique
  etsyListingId String   @unique
  productCount  Int      @default(0)
  minPrice      Float?
  maxPrice      Float?
  currency      String?
  quantity      Int      @default(0)
  rawJson       String
  syncedAt      DateTime @default(now())
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingKeyword {
  id        String   @id @default(cuid())
  listingId String
  keyword   String
  type      String
  source    String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingScore {
  id              String   @id @default(cuid())
  listingId       String
  seoScore        Int
  ctrScore        Int
  conversionScore Int
  brandScore      Int
  overallScore    Int
  scoreReasons    String
  fixPriorities   String
  createdAt       DateTime @default(now())
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model BestsellerScore {
  id                         String   @id @default(cuid())
  listingId                  String
  productMarketFitScore      Int
  searchDemandScore          Int
  competitionScore           Int
  giftPotentialScore         Int
  visualHookScore            Int
  profitPotentialScore       Int
  seasonalityScore           Int
  aiSearchPotentialScore     Int
  bestsellerPotentialScore   Int
  verdict                    String
  reasons                    String
  nextActions                String
  createdAt                  DateTime @default(now())
  listing                    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model OptimizationRecommendation {
  id               String          @id @default(cuid())
  listingId        String
  type             String
  priority         String
  currentValue     String
  suggestedValue   String
  reason           String
  expectedImpact   String
  status           String          @default("pending")
  requiresApproval Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  listing          Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  approvalQueue    ApprovalQueue?
}

model ApprovalQueue {
  id               String                     @id @default(cuid())
  recommendationId String                     @unique
  actionType       String
  beforeSnapshot   String
  afterSnapshot    String
  status           String                     @default("pending")
  approvedAt       DateTime?
  appliedAt        DateTime?
  createdAt        DateTime                   @default(now())
  recommendation   OptimizationRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
}

model SyncLog {
  id             String    @id @default(cuid())
  shopId         String?
  source         String
  mode           String    @default("read_only")
  status         String
  message        String
  itemCount      Int
  listingsPulled Int       @default(0)
  imagesPulled   Int       @default(0)
  inventoryPulled Int      @default(0)
  receiptsPulled Int       @default(0)
  transactionsPulled Int   @default(0)
  errors         String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())
  shop           Shop?     @relation(fields: [shopId], references: [id], onDelete: SetNull)
}

model EtsyReceipt {
  id             String   @id @default(cuid())
  shopId         String
  etsyReceiptId  String   @unique
  status         String?
  buyerUserId    String?
  buyerEmail     String?
  name           String?
  totalPrice     Float?
  currency       String?
  createdTimestamp Int?
  updatedTimestamp Int?
  rawJson        String
  syncedAt       DateTime @default(now())
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model EtsyTransaction {
  id                String   @id @default(cuid())
  shopId            String
  etsyTransactionId String   @unique
  etsyReceiptId     String?
  etsyListingId     String?
  title             String?
  quantity          Int      @default(0)
  price             Float?
  currency          String?
  createdTimestamp  Int?
  rawJson           String
  syncedAt          DateTime @default(now())
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([etsyReceiptId])
  @@index([etsyListingId])
}

model EtsySyncState {
  id                 String   @id @default("etsy")
  shopId             String?
  status             String   @default("idle")
  message            String   @default("")
  error              String?
  listingsCount      Int      @default(0)
  imagesCount        Int      @default(0)
  inventoryCount     Int      @default(0)
  receiptsCount      Int      @default(0)
  transactionsCount  Int      @default(0)
  lastStartedAt      DateTime?
  lastFinishedAt     DateTime?
  updatedAt          DateTime @updatedAt
}

model EtsyGrowthPlan {
  id                  String   @id @default(cuid())
  listingId           String   @map("listing_id")
  batchKey            String   @map("batch_key")
  productName         String   @map("product_name")
  currentTitle        String   @map("current_title")
  currentIssues       String   @map("current_issues")
  trafficImpactReason String   @map("traffic_impact_reason")
  proposedTitle       String   @map("proposed_title")
  proposedTags        String   @map("proposed_tags")
  imageRecommendations String  @map("image_recommendations")
  priority            String
  expectedImpact      String   @map("expected_impact")
  status              String   @default("draft")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  listing             Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  baseline            EtsyGrowthBaseline?
  dailyTrackings      EtsyGrowthDailyTracking[]

  @@unique([batchKey, listingId])
  @@index([batchKey])
  @@index([priority])
  @@map("etsy_growth_plan")
}

model EtsyGrowthBaseline {
  id             String   @id @default(cuid())
  planId         String   @unique @map("plan_id")
  listingId      String   @map("listing_id")
  baselineDate   String   @map("baseline_date")
  views          Int      @default(0)
  favorites      Int      @default(0)
  orders         Int      @default(0)
  revenue        Float    @default(0)
  conversionRate Float    @default(0) @map("conversion_rate")
  snapshotJson   String   @map("snapshot_json")
  createdAt      DateTime @default(now()) @map("created_at")
  listing        Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  plan           EtsyGrowthPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([baselineDate])
  @@map("etsy_growth_baseline")
}

model EtsyGrowthDailyTracking {
  id             String   @id @default(cuid())
  planId         String?  @map("plan_id")
  listingId      String   @map("listing_id")
  trackingDate   String   @map("tracking_date")
  views          Int      @default(0)
  favorites      Int      @default(0)
  orders         Int      @default(0)
  revenue        Float    @default(0)
  conversionRate Float    @default(0) @map("conversion_rate")
  source         String   @default("local_etsy_sync")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  listing        Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  plan           EtsyGrowthPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@unique([listingId, trackingDate])
  @@index([trackingDate])
  @@index([planId])
  @@map("etsy_growth_daily_tracking")
}

model CompetitorSnapshot {
  id               String   @id @default(cuid())
  title            String
  price            Float
  tags             String
  description      String
  reviewCount      Int
  imageNotes       String
  comparisonReport String
  createdAt        DateTime @default(now())
}

model PromotionTask {
  id          String   @id @default(cuid())
  listingId   String
  channel     String
  taskDate    DateTime
  title       String
  description String
  status      String   @default("planned")
  createdAt   DateTime @default(now())
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ExportLog {
  id        String   @id @default(cuid())
  listingId String
  filePath  String
  status    String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model OpportunityHistory {
  id               String   @id @default(cuid())
  date             String   @unique
  topOpportunities String
  topActions       String
  createdAt        DateTime @default(now())
}

model WinningProductHistory {
  id           String   @id @default(cuid())
  date         String
  product      String
  winningScore Int
  verdict      String
  reason       String
  report       String
  createdAt    DateTime @default(now())
}
