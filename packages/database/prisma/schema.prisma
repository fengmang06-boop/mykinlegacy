  code        String   @unique @db.VarChar(128)
  description String?  @db.Text
  createdAt   DateTime @map("created_at") @db.DateTime(3)

  adminRolePermissions AdminRolePermission[]

  @@map("admin_permissions")
}

model AdminUserRole {
  id          String   @id @db.Char(26)
  adminUserId String   @map("admin_user_id") @db.Char(26)
  adminRoleId String   @map("admin_role_id") @db.Char(26)
  createdAt   DateTime @map("created_at") @db.DateTime(3)

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
  adminRole AdminRole @relation(fields: [adminRoleId], references: [id])

  @@unique([adminUserId, adminRoleId])
  @@index([adminRoleId])
  @@map("admin_user_roles")
}

model AdminRolePermission {
  id                String   @id @db.Char(26)
  adminRoleId       String   @map("admin_role_id") @db.Char(26)
  adminPermissionId String   @map("admin_permission_id") @db.Char(26)
  createdAt         DateTime @map("created_at") @db.DateTime(3)

  adminRole       AdminRole       @relation(fields: [adminRoleId], references: [id])
  adminPermission AdminPermission @relation(fields: [adminPermissionId], references: [id])

  @@unique([adminRoleId, adminPermissionId])
  @@index([adminPermissionId])
  @@map("admin_role_permissions")
}

model AuditLog {
  id           String    @id @db.Char(26)
  actorType    ActorType @map("actor_type")
  actorId      String?   @map("actor_id") @db.Char(26)
  action       String    @db.VarChar(128)
  entityType   String    @map("entity_type") @db.VarChar(64)
  entityId     String?   @map("entity_id") @db.Char(26)
  ipHash       String?   @map("ip_hash") @db.Char(64)
  beforeJson   Json?     @map("before_json")
  afterJson    Json?     @map("after_json")
  metadataJson Json?     @map("metadata_json")
  createdAt    DateTime  @map("created_at") @db.DateTime(3)

  @@index([actorType, actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model OutboxEvent {
  id            String       @id @db.Char(26)
  eventType     String       @map("event_type") @db.VarChar(128)
  aggregateType String       @map("aggregate_type") @db.VarChar(64)
  aggregateId   String       @map("aggregate_id") @db.Char(26)
  payloadJson   Json         @map("payload_json")
  status        OutboxStatus
  attempts      Int
  nextAttemptAt DateTime?    @map("next_attempt_at") @db.DateTime(3)
  createdAt     DateTime     @map("created_at") @db.DateTime(3)
  publishedAt   DateTime?    @map("published_at") @db.DateTime(3)

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@map("outbox_events")
}

model IdempotencyKey {
  id             String            @id @db.Char(26)
  scope          IdempotencyScope
  idempotencyKey String            @map("idempotency_key") @db.VarChar(255)
  requestHash    String            @map("request_hash") @db.Char(64)
  responseJson   Json?             @map("response_json")
  status         IdempotencyStatus
  expiresAt      DateTime          @map("expires_at") @db.DateTime(3)
  createdAt      DateTime          @map("created_at") @db.DateTime(3)
  updatedAt      DateTime          @map("updated_at") @db.DateTime(3)

  @@unique([scope, idempotencyKey])
  @@index([expiresAt])
  @@index([status])
  @@map("idempotency_keys")
}
