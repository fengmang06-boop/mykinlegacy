{
  "name": "@ai-heritage/database",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:format": "node scripts/prisma-cli.mjs format",
    "db:generate": "node scripts/prisma-cli.mjs generate",
    "db:migrate:deploy": "node scripts/prisma-cli.mjs migrate deploy",
    "db:migrate:dev": "node scripts/prisma-cli.mjs migrate dev",
    "db:seed": "node scripts/seed-cli.mjs",
    "db:studio": "node scripts/prisma-cli.mjs studio",
    "db:validate": "node scripts/prisma-cli.mjs validate",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.seed.json --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "prisma": "6.19.0",
    "tsx": "^4.22.4"
  }
}
