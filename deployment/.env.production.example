# MyKinLegacy production deployment example.
# Copy to deployment/.env.production on the server. Do not commit real secrets.

NODE_ENV=production
APP_ENV=production

PUBLIC_IP=216.128.154.152
DOMAIN=mykinlegacy.com
TLS_MODE=letsencrypt
LETSENCRYPT_EMAIL=support@mykinlegacy.com

APP_WEB_URL=https://mykinlegacy.com
API_PUBLIC_URL=https://mykinlegacy.com
NEXT_PUBLIC_SITE_URL=https://mykinlegacy.com
APP_BASE_URL=https://mykinlegacy.com
API_BASE_URL=https://mykinlegacy.com
NEXT_PUBLIC_API_BASE_URL=/api/v1

MYSQL_DATABASE=mykinlegacy
MYSQL_USER=mykinlegacy
MYSQL_PASSWORD=auto
MYSQL_ROOT_PASSWORD=auto

DATABASE_URL=mysql://mykinlegacy:auto@mysql:3306/mykinlegacy
DIRECT_URL=mysql://mykinlegacy:auto@mysql:3306/mykinlegacy
REDIS_URL=redis://redis:6379

API_PORT=4000
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_MS=5000
WORKER_ENABLE_OUTBOX_DISPATCHER=true

RUN_SEED=true

STRIPE_SECRET_KEY=sk_test_disabled
STRIPE_WEBHOOK_SECRET=whsec_disabled
STRIPE_API_VERSION=
STRIPE_SUCCESS_PATH=/payment/success
STRIPE_CANCEL_PATH=/payment/cancel

AI_PROVIDER=mock
AI_PROVIDER_API_KEY=disabled
OPENAI_API_KEY=disabled
OPENAI_IMAGE_MODEL=mock-image-model
OPENAI_TEXT_MODEL=mock-text-model
AI_GENERATION_TIMEOUT_MS=180000
AI_IMAGE_MAX_ATTEMPTS=3
AI_TEXT_MAX_ATTEMPTS=3

EMAIL_PROVIDER=mock
EMAIL_FROM=support@mykinlegacy.com
EMAIL_REPLY_TO=support@mykinlegacy.com
RESEND_API_KEY=disabled
SENDGRID_API_KEY=disabled
SES_REGION=us-east-1

STORAGE_PROVIDER=local_private
LOCAL_STORAGE_DIR=./.local-storage-production
STORAGE_BUCKET=mykinlegacy-local-private
S3_BUCKET=disabled
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=disabled
S3_SECRET_ACCESS_KEY=disabled
R2_BUCKET=disabled
R2_ACCOUNT_ID=disabled
R2_ACCESS_KEY_ID=disabled
R2_SECRET_ACCESS_KEY=disabled

ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=admin@mykinlegacy.com
ADMIN_BOOTSTRAP_PASSWORD=disabled
ADMIN_SESSION_SECRET=auto

RECOVERY_SCAN_ENABLED=true
RECOVERY_SCAN_INTERVAL_MS=300000
CLEANUP_DESTRUCTIVE_ENABLED=false
STUCK_ORDER_THRESHOLD_MINUTES=30
